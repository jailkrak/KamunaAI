{
  "model_type": "LSTM",
  "model_name": "TradingAI_v1",
  
  "input_config": {
    "sequence_length": 60,
    "num_features": 10,
    "feature_columns": [
      "open",
      "high", 
      "low",
      "close",
      "volume",
      "rsi",
      "macd",
      "bb_upper",
      "bb_lower",
      "ema_20"
    ]
  },
  
  "lstm_config": {
    "hidden_size": 256,
    "num_layers": 3,
    "dropout": 0.2,
    "bidirectional": true,
    "batch_first": true
  },
  
  "transformer_config": {
    "d_model": 128,
    "nhead": 8,
    "num_encoder_layers": 4,
    "num_decoder_layers": 0,
    "dim_feedforward": 512,
    "dropout": 0.1,
    "activation": "gelu"
  },
  
  "output_config": {
    "task_type": "regression",
    "output_size": 1,
    "prediction_horizon": 1,
    "target_column": "future_return"
  },
  
  "attention_config": {
    "use_attention": true,
    "attention_type": "multihead",
    "attention_dropout": 0.1
  },
  
  "training_config_ref": "train_config.json",
  
  "optimization": {
    "use_mixed_precision": true,
    "gradient_clipping": 1.0,
    "weight_decay": 0.0001
  },
  
  "quantization": {
    "enable_quantization": false,
    "quantization_type": "dynamic"
  },
  
  "feature_engineering": {
    "normalization": "minmax",
    "use_log_returns": true,
    "add_technical_indicators": true,
    "window_sizes": [10, 20, 50, 200]
  },
  
  "ensemble_config": {
    "use_ensemble": false,
    "models": ["LSTM", "Transformer", "XGBoost"],
    "ensemble_method": "weighted_average"
  }
}